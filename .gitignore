# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# tile build artifacts (large binary files — rebuild with scripts/build-tiles.sh)
/tiles/
/tmp/
/public/tiles/

# generated digest preview (output of scripts/news-digest.mjs --dry-run)
/public/digest-preview.html

# internal docs — operational plans, costs, domain info, dev notes
# keep locally and in nightly backup; not for public repo
docs/internal/
